<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="CRYpT v6.0 OBSIDIAN — COSTRINITY Cipher Protocol"
    Manufacturer="COSTRINITY"
    Version="6.0.1.0"
    UpgradeCode="A7C3D1E0-4F5B-4A8C-9D2E-1F6B3C8A0E5D"
    Scope="perUser">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of CRYpT is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="CRYpTIcon" SourceFile="icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="CRYpTIcon" />
    <Property Id="ARPHELPLINK" Value="https://costrinity.xyz/crypt" />
    <Property Id="ARPURLINFOABOUT" Value="https://costrinity.xyz/crypt" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/COSTRINITY/CRYpT-lite/releases" />
    <Property Id="ARPCONTACT" Value="co@costrinity.xyz" />
    <Property Id="ARPCOMMENTS" Value="17-Layer Cascade Encryption with 5-Cipher AEAD" />

    <!-- WiX Minimal UI: Welcome + License + Progress + Finish -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="CRYpT">

        <Component Id="MainExecutable" Guid="B8D4E2F1-5A3C-4B7D-8E1F-2C9A6D0F3B5E">
          <File Id="CRYpTExe" Source="..\CRYpT.exe" KeyPath="yes" />
        </Component>

        <Component Id="DesktopShortcutComp" Guid="C9E5F3A2-6B4D-4C8E-9F2A-3D0B7E1F4C6A">
          <RegistryValue
            Root="HKCU"
            Key="Software\COSTRINITY\CRYpT"
            Name="DesktopShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
          <Shortcut
            Id="DesktopShortcut"
            Directory="DesktopFolder"
            Name="CRYpT"
            Description="COSTRINITY Cipher Protocol — 17-Layer File Encryption"
            Target="[#CRYpTExe]"
            Icon="CRYpTIcon"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFile Id="RemoveDesktopShortcut" Name="CRYpT.lnk" On="uninstall" Directory="DesktopFolder" />
        </Component>

        <Component Id="StartMenuShortcutComp" Guid="E1A7B5C3-8D6F-4E0A-B14C-5F2D9A3E6B8C">
          <RegistryValue
            Root="HKCU"
            Key="Software\COSTRINITY\CRYpT"
            Name="StartMenuShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
          <Shortcut
            Id="StartMenuShortcut"
            Directory="ProgramMenuFolder"
            Name="CRYpT — COSTRINITY"
            Description="COSTRINITY Cipher Protocol — 17-Layer File Encryption"
            Target="[#CRYpTExe]"
            Icon="CRYpTIcon"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFile Id="RemoveStartMenuShortcut" Name="CRYpT — COSTRINITY.lnk" On="uninstall" Directory="ProgramMenuFolder" />
        </Component>

        <Component Id="CryptFileAssoc" Guid="D0F6A4B3-7C5E-4D9F-A03B-4E1C8F2A5D7B">
          <RegistryValue
            Root="HKCU"
            Key="Software\COSTRINITY\CRYpT"
            Name="FileAssoc"
            Type="integer"
            Value="1"
            KeyPath="yes" />
          <RegistryValue Root="HKCU" Key="Software\Classes\.crypt" Type="string" Value="CRYpT.EncryptedFile" />
          <RegistryValue Root="HKCU" Key="Software\Classes\CRYpT.EncryptedFile" Type="string" Value="CRYpT Encrypted File" />
          <RegistryValue Root="HKCU" Key="Software\Classes\CRYpT.EncryptedFile\DefaultIcon" Type="string" Value="[#CRYpTExe],0" />
          <RegistryValue Root="HKCU" Key="Software\Classes\CRYpT.EncryptedFile\shell\open\command" Type="string" Value="&quot;[#CRYpTExe]&quot; &quot;%1&quot;" />
        </Component>

      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="CRYpT v6.0 OBSIDIAN" Level="1"
             Description="COSTRINITY Cipher Protocol — 17-Layer Cascade Encryption">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="DesktopShortcutComp" />
      <ComponentRef Id="StartMenuShortcutComp" />
      <ComponentRef Id="CryptFileAssoc" />
    </Feature>

  </Package>
</Wix>
